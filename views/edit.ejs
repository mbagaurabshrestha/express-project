<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Post</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
<div class="w-full min-h-screen bg-zinc-900 text-white p-10">

<div class="flex w-full justify-end">
<a class="bg-red-500 rounded-md text-sm px-3 py-2 mb-5 inline-block" href="/logout">Logout</a>
</div>

<h5 class="mb-5">Edit your post</h5>

<form method="post" action="/update/<%= post._id %>" class="text-white">
<textarea name="content" class="w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md outline-none" placeholder="Edit your post here">
<%= post.content %>
</textarea>
         
<input type="Submit" class="text-sm px-3 w-40 py-2 bg-yellow-500 text-black font-bold rounded-md block mt-2">
        
</form>
</div>
</body>
</html>