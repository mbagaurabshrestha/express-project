<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <h3 class="text-3xl mb-4">Login Your Account</h3>

    <form action="/login" method="post">
        
        <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md" type="text" placeholder="email" name="email"/>
        
        <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-md" type="password" placeholder="password" name="password"/>

        <input class="px-3 py-2 bg-blue-500 border-2 rounded-md" type="submit" value="Login Account"/>

    </form>
    </div>
</body>
</html>